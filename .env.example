# Optional — persistent storage on Vercel (connect ONE in Vercel → Storage)
# Upstash Redis (recommended):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# OR Vercel Blob:
# BLOB_READ_WRITE_TOKEN=

# Whop (required for production — app only works inside this business)
# WHOP_API_KEY=
# WHOP_APP_ID=
# WHOP_COMPANY_ID=biz_xxx   ← required: locks app to this business only
# WHOP_EXPERIENCE_ID=exp_xxx
# WHOP_ACCOUNTABILITY_CHANNEL_ID=feed_xxx   ← daily accountability chat (feed_ or exp_)

# Dev defaults (admin=1 bypass only works outside production/preview, or set ALLOW_DEV_ADMIN=1)
DEFAULT_TIER=basic
DEV_ADMIN=0
# ALLOW_DEV_ADMIN=0

# Comma-separated Whop plan IDs that map to Pro tier (when Whop auth is wired)
# WHOP_PRO_PLAN_IDS=plan_xxx,plan_yyy

# Multi-company storage — disabled; all businesses share one store (eod-tracker/store.json on Blob).
# DEFAULT_COMPANY_ID=biz_xxx
